{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HomenShum/NodeTasks/schemas/node-task.schema.json",
  "title": "NodeTask",
  "type": "object",
  "required": ["id", "family", "surface", "goal", "steps", "assertions", "artifacts", "sourceRefs"],
  "properties": {
    "id": { "type": "string", "minLength": 3 },
    "family": { "type": "string" },
    "surface": { "type": "string" },
    "route": { "type": "string" },
    "persona": { "type": "string" },
    "goal": { "type": "string" },
    "setup": { "type": "array", "items": { "type": "string" } },
    "steps": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "assertions": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "artifacts": { "type": "array", "items": { "type": "string" } },
    "sourceRefs": { "type": "array", "items": { "type": "string" } },
    "timeoutMs": { "type": "integer", "minimum": 1000 },
    "officialScoreClaim": { "type": "boolean" },
    "risk": { "type": "string" },
    "rank": {
      "type": "object",
      "properties": {
        "domain": { "type": "string" },
        "subdomain": { "type": "string" },
        "domainPath": { "type": "array", "items": { "type": "string" } },
        "estimatedSteps": { "type": "number" },
        "stepTier": { "type": "string" },
        "costTier": { "type": "string" },
        "costRank": { "type": "number" },
        "estimatedCostUsd": { "type": ["number", "null"] },
        "costBasis": { "type": "string" },
        "difficultyScore": { "type": "number" },
        "difficultyTier": { "type": "string" },
        "difficultyReasons": { "type": "array", "items": { "type": "string" } },
        "topTags": { "type": "array", "items": { "type": "string" } },
        "personaFit": { "type": "array", "items": { "type": "string" } }
      }
    },
    "curation": {
      "type": "object",
      "properties": {
        "summary": { "type": "string" },
        "whyItMatters": { "type": "string" },
        "firstRun": { "type": "string" },
        "caution": { "type": "string" },
        "scoreBoundary": { "type": "string" },
        "recommendedFor": { "type": "array", "items": { "type": "string" } },
        "quality": { "type": "string" }
      }
    },
    "provenance": {
      "type": "object",
      "properties": {
        "suiteLineage": { "type": "array", "items": { "type": "string" } },
        "primarySuite": { "type": "string" },
        "verifierType": { "type": "string" },
        "scoreStatus": { "type": "string" },
        "productPathCompletion": { "type": "string" },
        "officialSemanticScore": { "type": "string" },
        "sourceCount": { "type": "number" },
        "sourceKinds": { "type": "array", "items": { "type": "string" } },
        "receiptExpectations": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
